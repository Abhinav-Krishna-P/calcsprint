rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if user is authenticated and is accessing their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Usernames uniqueness rules
    match /usernames/{usernameLower} {
      allow read: if isAuthenticated();
      // Allow writing if the user specifies their own UID
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Scores rules
    match /scores/{scoreId} {
      allow read: if isAuthenticated();
      // Users can only submit or update scores that belong to them
      allow create, update: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
